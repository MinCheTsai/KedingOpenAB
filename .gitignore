# 環境變數（含 token、密鑰）
.env

# 角色的工作產出（clone 的 repo、AI 產生的檔案）
agents/*/projects/
agents/*/.cache/
agents/*/.conda/
agents/*/.config/
agents/*/.local/
agents/*/.semantic_search/
agents/*/miniconda3/
agents/*/data/
agents/*/.bash_history
agents/*/.gitconfig

# kiro-cli session 資料
agents/*/.kiro/sessions/
agents/*/.kiro/settings/

# 動態記憶（每個環境不同）
agents/*/.kiro/steering/memory.md

# 舊的 steering 目錄（已搬到 agents/）
steering-old/

# Python
__pycache__/
*.pyc

# 臨時本地部署用（不進 git，正式部署由工程師依 docs/mcp-redmine-deploy.md 處理）
tmp/

# 本地工具腳本（含機器特定路徑）
scripts/*.bat

# Kiro IDE workspace 層級設定（含 MCP 連線，每個環境不同）
.kiro/settings/

# 共享檔案交換區（每日清空，暫存檔不進 git）
shared/drop/*
!shared/drop/.gitkeep

# 舊方案 mcp-redmine clone（已改用 redmine-mcp-server，參考 docs/mcp-redmine-setup.md）
mcp-redmine/

# kiro-cli 自動產生的 agent config 範例
agents/*/.kiro/agents/

# Agent 狀態檔（由 agent 自動產生，不進 git）
agents/**/projects/**/_status.md

# OpenAB runtime 資料（thread_map、session 等）
agents/*/.openab/

# 容器內自動產生的 shell 設定
agents/*/.profile
agents/*/.zshrc
agents/*/.bashrc
agents/*/.npm/
agents/*/.kiro/.cli_bash_history

# IDE 個人設定
.vscode/

# 參考用 clone repo（有自己的 .git）
refs/

# 客訴專案暫存（正式文件在其他地方管理）
customer-complaint/
