# 🏝️ 比奇堡開發團隊 — 環境變數範本
# 複製此檔案為 .env 並填入實際值

# ─── Discord Bot Tokens（每個角色一個 Discord Application）───
DISCORD_BOT_TOKEN_BOB=
DISCORD_BOT_TOKEN_PATRICK=
DISCORD_BOT_TOKEN_PUFF=
DISCORD_BOT_TOKEN_SQUIDWARD=
DISCORD_BOT_TOKEN_SANDY=
DISCORD_BOT_TOKEN_GARY=
DISCORD_BOT_TOKEN_CONCH=

# ─── Discord Channel IDs ───
CHANNEL_KRUSTY_KRAB=
CHANNEL_PLAZA=
CHANNEL_MEETING=
CHANNEL_LAB=
CHANNEL_REPORT=
CHANNEL_TV=
KIRO_USAGE_CHANNEL_ID=

# ─── Discord Slash Bot ───
DISCORD_GUILD_ID=
SLASH_BOT_CHANNEL_ID=

# ─── Magic Conch（容器管理 Bot）───
CONCH_ADMIN_IDS=
CONCH_OPERATOR_ROLE_IDS=

# ─── Kiro CLI API Keys（每個角色一把）───
KIRO_API_KEY_BOB=
KIRO_API_KEY_PATRICK=
KIRO_API_KEY_PUFF=
KIRO_API_KEY_SQUIDWARD=
KIRO_API_KEY_SANDY=
KIRO_API_KEY_GARY=
KIRO_API_KEY_CONCH=
