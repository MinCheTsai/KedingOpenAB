# ─── AWS（slash-bot 查詢 Athena 用）───
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── WeCom Gateway（企業微信）───
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=

# ─── Redmine MCP ───
REDMINE_URL=
REDMINE_API_KEY_BOB=
